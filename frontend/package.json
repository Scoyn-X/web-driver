{
  "name": "frontend",
  "description": "复旦大学 2025-2026 学年第二学期软件工程（H）课程项目前端",
  "version": "0.0.1-SNAPSHOT",
  "private": true,
  "type": "module",
  "scripts": {
    "i": "pnpm install",
    "dev": "vite",
    "build": "vue-tsc --noEmit & vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint:eslint": "eslint --cache \"src/**/*.{vue,ts,js}\" --fix",
    "lint:prettier": "prettier --write \"**/*.{js,cjs,ts,json,css,scss,vue,html,md}\"",
    "lint:stylelint": "stylelint --cache \"**/*.{css,scss,vue}\" --fix",
    "lint:duplication": "jscpd src",
    "lint:lint-staged": "lint-staged",
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:stylelint && npm run lint:duplication",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report tests/e2e/report",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{cjs,json}": [
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix --no-warn-ignored",
      "prettier --write",
      "stylelint --fix"
    ],
    "*.html": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.{scss,css}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^12.8.2",
    "animate.css": "^4.1.1",
    "axios": "^1.13.2",
    "bpmn-js": "^18.16.1",
    "default-passive-events": "^2.0.0",
    "element-plus": "^2.11.8",
    "exceljs": "^4.4.0",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "path-to-regexp": "^8.3.0",
    "pinia": "^3.0.4",
    "qs": "^6.14.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.1",
    "@iconify/utils": "^2.3.0",
    "@playwright/test": "^1.49.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@types/nprogress": "^0.2.3",
    "@types/path-browserify": "^1.0.3",
    "@types/qs": "^6.14.0",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.22",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "sass": "^1.94.0",
    "stylelint": "^16.25.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^6.1.0",
    "stylelint-config-recommended": "^15.0.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-prettier": "^5.0.3",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "unocss": "^66.5.6",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^7.2.2",
    "vite-plugin-mock-dev-server": "^2.0.2",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "第 14 小组",
  "license": "MIT"
}
